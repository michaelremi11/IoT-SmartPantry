# =============================================================================
# Smart Pantry + Kitchen Hub — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values from the Firebase Console.
# NEVER commit the real .env file to version control.
# =============================================================================

# --- Firebase Project Config (shared across all services) ---
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Firebase Admin SDK (server-side / hub / analytics) ---
# Path to the service account JSON key file downloaded from Firebase Console
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# --- Firestore Collections (optional overrides) ---
FIRESTORE_PANTRY_COLLECTION=pantryItems
FIRESTORE_SHOPPING_COLLECTION=shoppingList
FIRESTORE_LOGS_COLLECTION=environmentLogs
FIRESTORE_ANALYTICS_COLLECTION=analyticsEvents

# --- Hub (Raspberry Pi) Settings ---
HUB_DEVICE_ID=hub-rpi4-001
HUB_TEMP_LOG_INTERVAL_SECONDS=300

# --- Analytics Service ---
ANALYTICS_PORT=8001
LOW_STOCK_THRESHOLD_DAYS=3
ANOMALY_TEMP_HIGH_C=30
ANOMALY_TEMP_LOW_C=10
ANOMALY_HUMIDITY_HIGH_PERCENT=80
ANOMALY_HUMIDITY_LOW_PERCENT=20

# --- Next.js Web Dashboard (prefix with NEXT_PUBLIC_ for client exposure) ---
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --- FastAPI Brain Service (called by Kivy hub) ---
BRAIN_API_URL=http://127.0.0.1:8000

# --- SKU Client Offline Cache ---
# SQLite DB path (relative to project root on Pi)
SKU_CACHE_DB=hub/data/sku_cache.db
# Timeout in seconds for each /lookup/{sku} HTTP call
SKU_LOOKUP_TIMEOUT_S=8.0
# How often (seconds) the sync monitor checks for connectivity
SKU_SYNC_INTERVAL_S=30
# Max retry attempts before a queued scan is abandoned
SKU_MAX_RETRIES=5

# --- Ollama Local LLM ---
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3.2:1b
# Max seconds to wait for model inference (Pi 4 needs ~30-45 s for cold start)
OLLAMA_TIMEOUT_S=60

# --- RAM Guard ---
# Available RAM (MB) below which Ollama requests are blocked
RAM_GUARD_THRESHOLD_MB=500
# Seconds between /proc/meminfo polls
RAM_GUARD_POLL_INTERVAL=10
# Flag file path (written by ram_guard.py daemon)
RAM_GUARD_FLAG_FILE=/run/smart-pantry/ram_ok

# --- Buy Signal Analytics ---
BUY_MORE_THRESHOLD_DAYS=3
BUY_MORE_RATE_MULTIPLIER=1.5
BUY_LESS_EXPIRY_RATIO=0.40
SIGNAL_MIN_EVENTS=3
SIGNAL_LOOKBACK_DAYS=30
